# .env.defaults should not contain private information.
# Copy to .env for local overrides.

# Use local Fluid service by default for frictionless forks.
VITE_FLUID_CLIENT=local

# Tinylicious relay endpoint. Defaults to the local dev relay (http://localhost:7070).
# For online play, point this at a hosted tinylicious (e.g. Fly.io) over https/wss.
# VITE_TINYLICIOUS_ENDPOINT=https://<your-relay-app>.fly.dev

# Optional: external semantic-edit endpoint
# VITE_LLM_ENDPOINT=https://your-llm-endpoint

# Supabase leaderboard (server-only; set in Vercel project env for production).
# Consumed by the /api/leaderboard serverless function.
# SUPABASE_URL=https://<project-ref>.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# Supabase room-code lookup (public anon key — safe to ship in the client bundle).
# Optional overrides; the client already ships working public defaults in code, so
# 4-digit room codes resolve directly from the browser across tabs/devices even in
# local dev (plain `vite serve`, no serverless functions). RLS only permits select
# + 4-digit insert on the room_codes table.
# VITE_SUPABASE_URL=https://<project-ref>.supabase.co
# VITE_SUPABASE_ANON_KEY=<public-anon-key>

# Azure Fluid Relay (required only when VITE_FLUID_CLIENT=azure)
# VITE_AZURE_TENANT_ID=<tenant-id>
# VITE_AZURE_ORDERER=<orderer-url>
# VITE_AZURE_FUNCTION_TOKEN_PROVIDER_URL=/api/fluid-token
# AZURE_FLUID_TENANT_KEY=<tenant-primary-key>   # server-only, used by /api/fluid-token
